<!DOCTYPE html>
<html>
<head>
<title>Verify OTP</title>
<style>
body{
font-family: Arial;
background:#020617;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
color:white;
}

.card{
background:#111827;
padding:40px;
border-radius:10px;
width:320px;
text-align:center;
}

input{
width:100%;
padding:12px;
margin-top:15px;
border:none;
border-radius:6px;
}

button{
margin-top:20px;
width:100%;
padding:12px;
background:#22c55e;
border:none;
color:white;
border-radius:6px;
cursor:pointer;
}
</style>
</head>

<body>

<div class="card">

<h2>OTP Verification</h2>

<form method="POST">

<input type="text" name="otp" placeholder="Enter OTP">

<button type="submit">
Verify OTP
</button>

</form>

</div>

</body>
</html>
